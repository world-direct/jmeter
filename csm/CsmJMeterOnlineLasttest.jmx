<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3-SNAPSHOT 34a2785">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="CSM Lasttest">
      <stringProp name="TestPlan.comments">Lasttests um die Grundperformance des CSM Service zu messen</stringProp>
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments" testname="User Defined Variables">
        <collectionProp name="Arguments.arguments"/>
      </elementProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.serialize_threadgroups">false</boolProp>
    </TestPlan>
    <hashTree>
      <ThreadGroup guiclass="ThreadGroupGui" testclass="ThreadGroup" testname="Standard Threads">
        <stringProp name="TestPlan.comments">Zu schaffen sind folgende Anforderungen
50 Tx/Sec
min 10 Requests gleichzeitig
300ms max. Response Time</stringProp>
        <intProp name="ThreadGroup.num_threads">10</intProp>
        <intProp name="ThreadGroup.ramp_time">10</intProp>
        <boolProp name="ThreadGroup.same_user_on_next_iteration">true</boolProp>
        <stringProp name="ThreadGroup.on_sample_error">continue</stringProp>
        <elementProp name="ThreadGroup.main_controller" elementType="LoopController" guiclass="LoopControlPanel" testclass="LoopController" testname="Loop Controller">
          <intProp name="LoopController.loops">-1</intProp>
          <boolProp name="LoopController.continue_forever">false</boolProp>
        </elementProp>
      </ThreadGroup>
      <hashTree>
        <ConstantThroughputTimer guiclass="TestBeanGUI" testclass="ConstantThroughputTimer" testname="Limit Troughput">
          <intProp name="calcMode">1</intProp>
          <doubleProp>
            <name>throughput</name>
            <value>3000.0</value>
            <savedValue>0.0</savedValue>
          </doubleProp>
          <stringProp name="TestPlan.comments">Limit to 50 Tx/sec</stringProp>
        </ConstantThroughputTimer>
        <hashTree/>
        <TCPSampler guiclass="TCPSamplerGui" testclass="TCPSampler" testname="59panid_0800_appexp_2112_keyid_060001_issue_28_online_validate_tan_with_mac.txt">
          <stringProp name="TestPlan.comments">Validate TAN mit online Schnittstelle
Tan ist OK

Damit diese hier funktiomiert ist in user.properties von jmeter 
tcp.BinaryTCPClient.eomByte=4
tcp.BinaryTCPClient.eomBytePosition=5
hinterlegt.</stringProp>
          <stringProp name="TCPSampler.classname">BinaryTCPClientSimpleImpl</stringProp>
          <stringProp name="TCPSampler.server">172.17.80.1</stringProp>
          <boolProp name="TCPSampler.reUseConnection">false</boolProp>
          <stringProp name="TCPSampler.port">7138</stringProp>
          <boolProp name="TCPSampler.nodelay">false</boolProp>
          <stringProp name="TCPSampler.timeout"></stringProp>
          <stringProp name="TCPSampler.request"></stringProp>
          <boolProp name="TCPSampler.closeConnection">false</boolProp>
          <stringProp name="ConfigTestElement.username"></stringProp>
          <stringProp name="ConfigTestElement.password"></stringProp>
        </TCPSampler>
        <hashTree/>
        <TCPSampler guiclass="TCPSamplerGui" testclass="TCPSampler" testname="ONLINE_VALIDATE_TAN_WITH_MAC_OLD" enabled="false">
          <stringProp name="TestPlan.comments">Validate TAN mit online Schnittstelle
Tan ist OK

Damit diese hier funktiomiert ist in user.properties von jmeter 
tcp.BinaryTCPClient.eomByte=4
tcp.BinaryTCPClient.eomBytePosition=5
hinterlegt.

Old bedeutet, dass aus der RandomNumber nicht der SessionKey vom Macabgeleitet wird, sondern es wird für die Mac Berechnung direkt der Mac verwendet.</stringProp>
          <stringProp name="TCPSampler.classname">BinaryTCPClientSimpleImpl</stringProp>
          <stringProp name="TCPSampler.server">10.1.4.211</stringProp>
          <boolProp name="TCPSampler.reUseConnection">true</boolProp>
          <stringProp name="TCPSampler.port">7138</stringProp>
          <boolProp name="TCPSampler.nodelay">false</boolProp>
          <stringProp name="TCPSampler.timeout">300</stringProp>
          <stringProp name="TCPSampler.request"></stringProp>
          <boolProp name="TCPSampler.closeConnection">false</boolProp>
          <stringProp name="ConfigTestElement.username"></stringProp>
          <stringProp name="ConfigTestElement.password"></stringProp>
        </TCPSampler>
